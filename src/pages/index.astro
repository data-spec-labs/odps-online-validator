---
import Base from '../layouts/Base.astro';
import Validator from '../components/Validator';
import '../styles/global.css';
---

<Base>
  <header class="bg-white border-b border-slate-200 sticky top-0 z-30">
    <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-10 py-4 lg:py-5 flex items-center justify-between gap-4 min-h-[4rem] lg:min-h-[5rem]">
      <div class="flex items-center gap-3.5 min-w-0">
        <img src="/favicon.svg" alt="" class="w-8 h-8 rounded-lg shrink-0" width="32" height="32" />
        <div class="min-w-0">
          <h1 class="font-bold text-slate-900 text-base lg:text-lg leading-snug truncate">ODPS Family Validator</h1>
          <p class="hidden lg:block text-sm text-slate-500 leading-snug mt-0.5 truncate">Paste YAML or JSON • In-browser • No data leaves your machine • Supports ODPS, ODPC, ODPG and ODPV</p>
        </div>
      </div>
      <div class="flex items-center gap-2 shrink-0">
        <a
                  href="https://odcs-validator.com/"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm font-medium text-slate-700 hover:border-slate-300 hover:bg-slate-50 hover:text-slate-900 transition-colors"
                >
                  <span class="hidden sm:inline">ODCS Validator</span>
                  <span class="sm:hidden">ODCS</span>
                  <span class="text-slate-400" aria-hidden="true">↗</span>
                </a>
        <a
          href="https://github.com/data-spec-labs/odps-online-validator"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm font-medium text-slate-700 hover:border-slate-300 hover:bg-slate-50 hover:text-slate-900 transition-colors"
          aria-label="View source on GitHub"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          <span class="hidden sm:inline">GitHub</span>
        </a>
      </div>
    </div>
  </header>

  <main class="bg-slate-50 min-h-screen">
    <section class="lg:hidden px-4 sm:px-6 pt-5 pb-2">
      <p class="text-sm text-slate-600 leading-snug">
        Validate Open Data Products standards instantly. Paste YAML or JSON below.
      </p>
      <div class="mt-2 flex flex-wrap gap-1.5">
        {['ODPS 4.1', 'ODPS 4.0', 'ODPC 1.0', 'ODPG 1.0', 'ODPV 1.0'].map((v) => (
          <span class="px-2 py-0.5 rounded-full bg-white border border-slate-200 text-slate-600 font-mono text-[11px]">
            {v}
          </span>
        ))}
      </div>
    </section>

    <section id="validator" class="max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-4 lg:py-3 lg:min-h-[calc(100dvh-5rem)] lg:flex lg:flex-col">
      <Validator client:load />
    </section>

    <section class="bg-white border-y border-slate-200 py-14 px-4 sm:px-6 lg:px-8">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-2xl font-bold text-slate-900 mb-2">Supported standards</h2>
        <p class="text-slate-500 mb-6 text-sm">
          The validator auto-detects the document kind (ODPS, ODPC, ODPG, or ODPV) and reads the root
          <code class="font-mono text-xs bg-slate-100 px-1 rounded">version</code> field to select the matching bundled JSON Schema.
          Unknown versions fall back to the latest schema for that standard with a warning.
        </p>
        <div class="overflow-x-auto rounded-xl border border-slate-200">
          <table class="w-full text-sm">
            <thead class="bg-slate-50 border-b border-slate-200">
              <tr>
                <th class="text-left px-4 py-3 font-semibold text-slate-700">Standard</th>
                <th class="text-left px-4 py-3 font-semibold text-slate-700">Versions</th>
                <th class="text-left px-4 py-3 font-semibold text-slate-700">Detect by</th>
                <th class="text-left px-4 py-3 font-semibold text-slate-700">Status</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <tr class="hover:bg-slate-50">
                <td class="px-4 py-3 font-semibold text-slate-800">ODPS</td>
                <td class="px-4 py-3 font-mono text-indigo-700">4.1, 4.0</td>
                <td class="px-4 py-3 text-slate-600"><code class="font-mono text-xs">product</code> root object</td>
                <td class="px-4 py-3"><span class="px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-700 text-xs font-medium">4.1 latest</span></td>
              </tr>
              <tr class="hover:bg-slate-50">
                <td class="px-4 py-3 font-semibold text-slate-800">ODPC</td>
                <td class="px-4 py-3 font-mono text-slate-600">1.0</td>
                <td class="px-4 py-3 text-slate-600"><code class="font-mono text-xs">kind: Catalog</code></td>
                <td class="px-4 py-3"><span class="px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-700 text-xs font-medium">Latest</span></td>
              </tr>
              <tr class="hover:bg-slate-50">
                <td class="px-4 py-3 font-semibold text-slate-800">ODPG</td>
                <td class="px-4 py-3 font-mono text-slate-600">1.0</td>
                <td class="px-4 py-3 text-slate-600"><code class="font-mono text-xs">kind: Graph</code></td>
                <td class="px-4 py-3"><span class="px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-700 text-xs font-medium">Latest</span></td>
              </tr>
              <tr class="hover:bg-slate-50">
                <td class="px-4 py-3 font-semibold text-slate-800">ODPV</td>
                <td class="px-4 py-3 font-mono text-slate-600">1.0.0</td>
                <td class="px-4 py-3 text-slate-600"><code class="font-mono text-xs">id: ODPV</code></td>
                <td class="px-4 py-3"><span class="px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-700 text-xs font-medium">Latest</span></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section id="faq" class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
      <h2 class="text-2xl font-bold text-slate-900 mb-8">Frequently asked questions</h2>
      <div class="space-y-4">
        {[
          {
            q: 'What is the Open Data Products standards family?',
            a: 'It is a set of Linux Foundation open specifications for data products: ODPS defines a single data product, ODPC organizes catalogs and portfolios, ODPG connects value relationships as graphs, and ODPV provides shared vocabulary. Together they support discovery, governance, and AI-ready metadata.',
          },
          {
            q: 'What ODPS versions does this validator support?',
            a: 'ODPS 4.1 (latest production) and 4.0. Older ODPS versions (3.x, 2.x) are not supported. The validator reads the root version field and selects the matching schema automatically.',
          },
          {
            q: 'How does the validator know which standard to use?',
            a: 'ODPC documents have kind: Catalog, ODPG has kind: Graph, ODPV has id: ODPV, and ODPS documents have a product root object. If the kind cannot be detected, validation cannot proceed.',
          },
          {
            q: 'Can I use JSON instead of YAML?',
            a: 'Yes. Both formats are supported equally. The validator auto-detects JSON or YAML from the pasted content.',
          },
          {
            q: 'Is my document sent to a server?',
            a: 'No. All validation runs entirely in your browser. Official JSON Schemas are bundled with the page. Your document never leaves your machine.',
          },
          {
            q: 'What is the difference between version and productVersion?',
            a: 'version identifies the specification version your file follows (e.g. 4.1 for ODPS). productVersion is the data product\'s own semver in product.details, tracking changes to the product metadata over time.',
          },
          {
            q: 'How is ODPS different from ODCS?',
            a: 'ODPS describes a data product as a business asset (metadata, SLA, quality, pricing, strategy). ODCS (Open Data Contract Standard) formalizes the agreement between data producers and consumers (schema, quality rules, team, IAM). ODPS can reference ODCS contracts via the contract object.',
          },
          {
            q: 'Where can I learn more?',
            a: 'Official documentation: https://opendataproducts.org/. ODPS 4.1 spec: https://opendataproducts.org/v4.1/. Examples: https://github.com/Open-Data-Product-Initiative/odps-examples.',
          },
        ].map(({ q, a }) => (
          <details class="group bg-white border border-slate-200 rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between px-5 py-4 cursor-pointer font-semibold text-slate-800 hover:bg-slate-50 transition-colors list-none">
              <span>{q}</span>
              <svg class="w-4 h-4 text-slate-400 transition-transform group-open:rotate-180 shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-5 pb-5 text-sm text-slate-600 leading-relaxed border-t border-slate-100 pt-4">{a}</div>
          </details>
        ))}
      </div>
    </section>
  </main>

  <footer class="border-t border-slate-200 bg-white py-4 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-center sm:justify-between gap-2 text-xs text-slate-500">
      <span>© {new Date().getFullYear()} ODPS Family Validator</span>
      <nav class="flex flex-wrap items-center justify-center gap-x-3 gap-y-1">
        <a href="https://docs.google.com/forms/d/e/1FAIpQLSdzjtAvESFGdLmRt-SspnoWxkIB5At9A0Pwwz5puzlz7o_3Vg/viewform?usp=sharing&ouid=115282285531220758681" target="_blank" rel="noopener" class="hover:text-indigo-600 transition-colors">Feedback</a>
        <span class="text-slate-300" aria-hidden="true">·</span>
        <a href="https://opendataproducts.org/" target="_blank" rel="noopener" class="hover:text-indigo-600 transition-colors">ODPS Spec</a>
        <span class="text-slate-300" aria-hidden="true">·</span>
        <a href="https://github.com/data-spec-labs/odps-online-validator" target="_blank" rel="noopener" class="hover:text-indigo-600 transition-colors">GitHub</a>
        <span class="text-slate-300" aria-hidden="true">·</span>
        <a href="https://www.apache.org/licenses/LICENSE-2.0" target="_blank" rel="noopener" class="hover:text-indigo-600 transition-colors">Apache 2.0</a>
      </nav>
    </div>
  </footer>
</Base>
